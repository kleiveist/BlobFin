{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the BlobFin main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:allow-save",
    "dialog:allow-open",
    "fs:default",
    "fs:read-files",
    "fs:write-files",
    "fs:read-dirs",
    "fs:read-meta",
    "fs:scope"
  ]
}
